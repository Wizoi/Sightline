# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp
.vscode/
.idea/

# Claude Code: personal, machine-specific tool-permission allowlist —
# not shared project config (.claude/agents, skills, settings.json are).
.claude/settings.local.json

# Music files — never publish scores or samples (often copyrighted)
*.pdf

# Dependencies / build (not used today, here for safety)
node_modules/
dist/
*.log

# MediaPipe WASM runtime + model, fetched by scripts/fetch-mediapipe-assets.mjs
# (runs automatically before dev/build) so they're served same-origin instead
# of from a third-party CDN at runtime — not checked in, regenerated locally.
public/mediapipe/

# Tesseract.js OCR worker + core WASM + model, fetched by
# scripts/fetch-ocr-assets.mjs (same reasoning as above) — not checked in.
public/tesseract/

# Bravura (SIL OFL-licensed SMuFL music-engraving font), fetched by
# scripts/fetch-bravura-assets.mjs from a pinned upstream release tag (same
# self-hosting reasoning as above) — not checked in, regenerated locally.
public/fonts/
