{
  "name": "sightline",
  "version": "1.0.0",
  "private": true,
  "description": "Hands-free sheet-music page turner driven by webcam eye tracking.",
  "type": "module",
  "scripts": {
    "predev": "node scripts/fetch-mediapipe-assets.mjs && node scripts/fetch-ocr-assets.mjs",
